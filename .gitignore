.venv/
bandori-env/
raw/
template.yaml
restore

# Python
__pycache__/
*.pyc

# Generated CSVs — src/content/songs/*.yaml이 원본. converter 산출물·RSS inbox 모두 추적 안 함.
# src/content/songs/*.csv
# src/tools/*.csv

# src/tools/collect/rss_events.jsonl(이벤트 로그)은 git 추적 대상 — ignore하지 않음.
# (멱등 재계산으로 seen 원장 폐기 → rss_seen.json은 더 이상 쓰지 않음.)

# Regeneratable network cache files
src/tools/curate/verify_cache.json
src/tools/curate/plb_cache.json

# Copyrighted content
# 가사 채운 실제 파일(assets/lyrics/<band>.md)은 추적 금지.
# 단, 빈 템플릿(<band>_template.md)은 세션 간 공유용으로 추적 허용.
assets/lyrics/*
!assets/lyrics/*_template.md

# 멀티모달 클러스터 PoC — 음원 캐시·임시 파싱 산출물(가사/음원 = 저작물, 비커밋).
# src/content/cluster/keywords_2d.json(키워드 좌표)만 추적, 나머지 파생물은 무시.
src/content/cluster/audio_cache/
src/content/cluster/audio_full/
src/content/cluster/audio_drums/
# 언더스코어 접두 = 임시/파생/비교본(_ffbin·_songs·_sentences·_audio_map_clap)
src/content/cluster/_*
# 오디오 수집 진행상태(로컬 실시간 조회용, fetch_audio.py 매 곡 갱신) — 비커밋
src/content/cluster/fetch_progress.json

# 배포 산출물 — index.html 은 build.py 생성물(Pages 아티팩트로 배포, Option A).
# 자동화는 데이터 파일만 커밋 → 핫픽스와 생성물 충돌 회피.
# ⚠️ 커밋 해제(git rm --cached index.html)는 Pages Source="GitHub Actions" 전환 +
#    deploy.yml 첫 배포 성공 확인 후에(그 전엔 deploy-from-branch 가 이 파일을 서빙).
/index.html

# Secrets
.env